{
  "name": "@leandown/comark",
  "version": "0.0.1",
  "description": "Comark plugin for syntax-highlighting Lean 4 code blocks via the Lean LSP",
  "repository": {
    "url": "https://github.com/mzhang28/remark-lean"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun run build:js && bun run build:dts",
    "build:js": "bun build src/index.ts --outdir dist --format esm --target node",
    "build:dts": "tsc -p tsconfig.build.json"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "latest",
    "comark": "^0.4.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "comark": ">=0.1.0"
  },
  "dependencies": {
    "@leandown/core": "workspace:*"
  }
}
