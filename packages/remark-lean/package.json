{
  "name": "remark-lean",
  "version": "0.0.1",
  "description": "remark plugin for syntax-highlighting Lean 4 code blocks via the Lean LSP",
  "repository": {"url": "https://github.com/mzhang28/remark-lean"},
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./dist/index.d.ts"
    },
    "./runtime": {
      "import": "./src/runtime.ts",
      "types": "./dist/runtime.d.ts"
    },
    "./lean.css": "./src/lean.css"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./runtime": {
        "import": "./dist/runtime.js",
        "types": "./dist/runtime.d.ts"
      },
      "./lean.css": "./dist/lean.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:js:node && bun run build:js:browser && bun run build:dts && bun run build:css",
    "build:js:node": "bun build src/index.ts --outdir dist --format esm --target node",
    "build:js:browser": "bun build src/runtime.ts --outdir dist --format esm --target browser",
    "build:dts": "tsc -p tsconfig.build.json",
    "build:css": "cp src/lean.css dist/lean.css"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "latest",
    "playwright": "^1.60.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  }
}
